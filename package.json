{
  "name": "ai-skill-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "check-lines": "node scripts/check-lines.js",
    "sources:collect": "node scripts/collect-sources.js",
    "score:candidates": "node scripts/agent-score-candidates.js",
    "score:validate": "node scripts/validate-scoring-candidates.js",
    "score:review": "npm run score:candidates && npm run score:validate",
    "precheck": "npm run typecheck && npm run build && npm run check-lines",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "chart.js": "^4.5.1"
  }
}
